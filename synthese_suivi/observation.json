{ "chained": false,
  "description_field_name": "cd_nom",
  "display_properties": [
    "cd_nom",
    "periode"
  ],

  "display_list": [
    "cd_nom",
    "nb_couples",
    "nb_jeunes",
    "nb_ind",
    "comments"
  ],

  "specific": {
    "cd_nom": {
      "type_widget": "taxonomy",
      "attribut_label": "Taxon",
      "type_util": "taxonomy",
      "required": true,
      "id_list": "__MODULE.ID_LIST_TAXONOMY"
    },
  "nb_couples": {
      "type_widget": "number",
      "attribut_label": "Nombre total de couples",
      "hidden": "({meta}) => meta.parents.visit.properties.periode !== 'repro'",
      "required": false
    },
    "nb_jeunes": {
      "type_widget": "number",
      "attribut_label": "Nombre de jeunes",
      "hidden": "({meta}) => meta.parents.visit.properties.periode !== 'repro'",
      "required": false
    },
    "nb_ind": {
      "type_widget": "number",
      "attribut_label": "Nombre d'individus",
      "hidden": "({meta}) => meta.parents.visit.properties.periode !== 'hiver'",
      "required": false
    },
    "comments": {
      "type_widget": "textarea",
      "required": false
    }
  }
}
